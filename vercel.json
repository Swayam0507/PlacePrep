{
  "buildCommand": "npm run build",
  "installCommand": "npm install && cd server && npm install && cd ../client && npm install",
  "outputDirectory": "client/dist",
  "functions": {
    "server/server.js": {
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
